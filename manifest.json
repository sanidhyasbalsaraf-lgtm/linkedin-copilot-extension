{
  "manifest_version": 3,
  "name": "Outreach Copilot for LinkedIn",
  "version": "1.6.0",
  "description": "Independent tool, not affiliated with LinkedIn. Pulls the job description and hiring manager info from a LinkedIn job posting, then drafts a reply or outreach message in your own writing style using OpenAI.",
  "author": "Sanidhya Balsaraf",
  "homepage_url": "https://github.com/sanidhyasbalsaraf-lgtm/linkedin-copilot-extension",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.openai.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Outreach Copilot for LinkedIn",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fonts/*.woff2"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ],
  "options_page": "options.html"
}
